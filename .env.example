# Copy to .env and fill in. .env is gitignored.

# --- LLM via OpenRouter (OpenAI-compatible) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Swap this one value to change models later:
MODEL_ID=anthropic/claude-opus-4-8

# --- Ingestion: Unstructured serverless ---
UNSTRUCTURED_API_KEY=
UNSTRUCTURED_API_URL=https://api.unstructuredapp.io

# --- Truth store: MongoDB Atlas ---
MONGODB_URI=
MONGODB_DB=lexigraph

# --- Vector store: Qdrant Cloud ---
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_COLLECTION=index_a

# --- Retrieval: Cohere rerank ---
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5

# --- Embeddings (fastembed local defaults; dim must match dense model) ---
DENSE_EMBED_MODEL=BAAI/bge-small-en-v1.5
DENSE_EMBED_DIM=384
SPARSE_EMBED_MODEL=Qdrant/bm25
